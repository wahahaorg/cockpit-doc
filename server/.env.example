DATABASE_URL=postgresql+psycopg://kb_user:kb_password@localhost:5432/cockpit
APP_ENV=development
MAX_UPLOAD_BYTES=10485760

# 本地 Ollama（默认配置）
AI_ENABLED=true
AI_MODEL=qwen3:8b
OLLAMA_BASE_URL=http://192.168.2.124:11434/v1
OLLAMA_API_KEY=ollama
AI_TIMEOUT_SECONDS=60
AI_MAX_RETRIES=1
OCR_SERVICE_URL=http://192.168.2.124:18000/ocr
OCR_SERVICE_TIMEOUT_SECONDS=120
OCR_LOCAL_FALLBACK_ENABLED=false
INCOME_RECONCILIATION_STORAGE_DIR=storage

# 如需切换回阿里云百炼，注释上方 Ollama 配置，取消注释以下内容：
# AI_MODEL=qwen-plus
# OLLAMA_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# OLLAMA_API_KEY=sk-xxxxxxxxxxxxxxxx
