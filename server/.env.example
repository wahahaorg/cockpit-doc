DATABASE_URL=postgresql+psycopg://kb_user:kb_password@localhost:5432/cockpit
APP_ENV=development
MAX_UPLOAD_BYTES=10485760

# 阿里云百炼 Qwen（未配置时自动使用确定性模板解释）
AI_ENABLED=false
AI_MODEL=qwen-plus
DASHSCOPE_API_KEY=
# 推荐替换为百炼业务空间专属 compatible-mode/v1 地址
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AI_TIMEOUT_SECONDS=30
AI_MAX_RETRIES=1
