{
  "compilerOptions": {
    "target": "ES2020", "lib": ["DOM", "ES2020"], "jsx": "react-jsx", "module": "ESNext",
    "moduleResolution": "Bundler", "esModuleInterop": true, "skipLibCheck": true, "strict": true,
    "noUncheckedIndexedAccess": true, "baseUrl": ".", "paths": {
      "@/*": ["src/*"],
      "@umijs/max": ["src/.umi-production/exports"]
    }, "types": ["node"]
  },
  "include": ["src"]
}
