# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=kb_user
POSTGRES_PASSWORD=kb_password
POSTGRES_DB=cockpit
POSTGRES_PORT=5432

# ── 应用环境 ──────────────────────────────────────────────────────────────────
APP_ENV=production

# ── 本地 Ollama AI ────────────────────────────────────────────────────────────
AI_ENABLED=true
AI_MODEL=qwen3:8b
# Ollama 和 Docker 在同一台机器 → 用 host-gateway
OLLAMA_BASE_URL=http://host-gateway:11434/v1
# Ollama 在其他机器 → 改成对应 IP，例如：
# OLLAMA_BASE_URL=http://192.168.2.136:11434/v1
OLLAMA_API_KEY=ollama
AI_TIMEOUT_SECONDS=60
AI_MAX_RETRIES=1
